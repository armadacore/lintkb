{
  "name": "lintkb",
  "version": "0.2.0",
  "description": "AI-agnostic ESLint wrapper that enriches lint findings with concrete AI instructions pointing to a project-local Markdown knowledge base.",
  "type": "module",
  "bin": {
    "lintkb": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "lintkb": "node dist/cli/index.js"
  },
  "keywords": [
    "eslint",
    "lint",
    "ai",
    "knowledge-base",
    "typescript",
    "agent",
    "claude",
    "cursor",
    "developer-experience"
  ],
  "license": "MIT",
  "author": "Marcel Armada-Castellon",
  "repository": {
    "type": "git",
    "url": "https://github.com/armadacore/lintkb.git"
  },
  "bugs": {
    "url": "https://github.com/armadacore/lintkb/issues"
  },
  "homepage": "https://github.com/armadacore/lintkb#readme",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
